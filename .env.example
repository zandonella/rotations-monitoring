# Supabase (same project as mythic-shop-api; service role key)
SUPABASE_URL=
SUPABASE_KEY=

# Direct Postgres connection string for pg_dump backups
# (Supabase dashboard -> Connect -> Direct connection / Session pooler, port 5432)
SUPABASE_DB_URL=

# Discord alerts
DISCORD_WEBHOOK_URL=
DISCORD_MENTION_ROLE_ID=

# Site + Pi
SITE_URL=https://rotations.lol
WOL_API_IP=100.99.1.41
# Set to true once the VPS is on the tailnet and the Pi has the /health endpoint
PI_HEALTH_ENABLED=false

# Watchdog thresholds (minutes past next_expected_at)
DEGRADED_AFTER_MIN=5
ERROR_AFTER_MIN=20

# Check cadence (seconds)
HEARTBEAT_CHECK_INTERVAL_SEC=60
CHECK_INTERVAL_SEC=300

# Backups
BACKUP_ENABLED=true
# Daily backup time, UTC HH:MM (01:00 UTC = 1h after the daily reset/refresh)
BACKUP_AT_UTC=01:00
BACKUP_RETENTION_DAYS=14

# HTTP status server
PORT=8080
